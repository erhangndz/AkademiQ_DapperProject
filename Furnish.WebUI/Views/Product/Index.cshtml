@model IEnumerable<ResultProductDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Ürünler</h1>

<table class="table table-bordered table-hover">


    <tr>
        <th>#</th>
        <th>Görsel</th>
        <th>Ürün Adı</th>
        <th>Güncel Fiyat</th>
        <th>Orijinal Fiyat</th>
        <th>Kategori Adı</th>
        <th>İşlemler</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td><img src="@item.ImageUrl" style="height:75px;width:75px" />   </td>
            <td>@item.ProductName</td>
            <td>@item.Price ₺</td>
            <td>@item.OriginalPrice ₺</td>
            <td>@item.CategoryName</td>

            <td>
                <a class="btn btn-danger" 
                   onclick="deleteProduct(@item.Id)" >Sil</a>
                <a class="btn btn-info" href="/Product/UpdateProduct/@item.Id">Güncelle</a>
            </td>
        </tr>
    }
</table>
<a class="btn btn-dark" href="/Product/CreateProduct">Yeni Ürün Oluştur</a>




<script>
    function deleteProduct(id) {
        Swal.fire({
            title: "Silmek istediğinize emin misiniz?",
            text: "Bu işlemi geri alamazsınız!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            cancelButtonText: "İptal",
            confirmButtonText: "Evet, Sil!"
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Product/DeleteProduct/" + id;
            }
        });
    }
</script>